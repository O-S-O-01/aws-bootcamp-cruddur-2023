   #!/usr/bin/bash

CYAN='\033[0;36m'
NO_COLOR='\033[0m' 
LABEL="rds-update-sg-rule"
printf "${CYAN}== ${LABEL} ==${NO_COLOR}\n"

echo "DB_SG_ID=$DB_SG_ID"
echo "DB_SG_RULE_ID=$DB_SG_RULE_ID"
echo "MY_IP=$MY_IP"

aws ec2 modify-security-group-rules \
  --group-id $DB_SG_ID \
  --security-group-rules "SecurityGroupRuleId=$DB_SG_RULE_ID,SecurityGroupRule={IpProtocol=tcp,FromPort=5432,ToPort=5432,CidrIpv4=$MY_IP/32}"